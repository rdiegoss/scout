# ─────────────────────────────────────────────
# Local development (Supabase via Docker)
# Run `npm run db:start` to get these values
# ─────────────────────────────────────────────
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=<local-anon-key-printed-by-supabase-start>
VITE_API_URL=http://localhost:3001
NODE_ENV=development
PORT=3001

# ─────────────────────────────────────────────
# Production (set in Vercel dashboard — do NOT put real values here)
# https://supabase.com/dashboard/project/<ref>/settings/api
# ─────────────────────────────────────────────
# VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<your-anon-key>
# SUPABASE_URL=https://<your-project-ref>.supabase.co
# SUPABASE_SERVICE_KEY=<your-service-role-key>
